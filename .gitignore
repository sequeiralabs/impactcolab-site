# =============================================================================
# .gitignore — HTML / CSS / JavaScript project (macOS)
# =============================================================================

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon

# Thumbnails
._*

# Files that might appear on external disk
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# -----------------------------------------------------------------------------
# Node.js / npm / yarn (common in JS tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/
.vite/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.map
.sass-cache/
.eslintcache
.stylelintcache
